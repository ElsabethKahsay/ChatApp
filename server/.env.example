PORT=3000

# MongoDB Atlas — get from Atlas dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/securechat?retryWrites=true&w=majority

# Cloudflare R2 — create API token in Cloudflare dashboard → R2 → API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=securechat-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
