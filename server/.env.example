PORT=3000

# MongoDB Atlas — get from Atlas dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/securechat?retryWrites=true&w=majority


# Backblaze B2 Configuration
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com
B2_ACCESS_KEY_ID=your_key_id_from_backblaze
B2_SECRET_ACCESS_KEY=your_application_key_from_backblaze
B2_BUCKET=securechat-media