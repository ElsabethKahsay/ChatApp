PORT=3000

# MongoDB Atlas — get from Atlas dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/securechat?retryWrites=true&w=majority

# JWT Secret - generate a strong random string for production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS - for development use * (all origins), for production set to your app domain
# Example for Android testing: CORS_ORIGIN=http://192.168.1.114,http://localhost:3000
CORS_ORIGIN=*

# Redis URL (optional) - for scaling to multiple server instances
# REDIS_URL=redis://localhost:6379

# Backblaze B2 Configuration
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com
B2_REGION=us-west-002
B2_ACCESS_KEY_ID=your_key_id_from_backblaze
B2_SECRET_ACCESS_KEY=your_application_key_from_backblaze
B2_BUCKET=securechat-media